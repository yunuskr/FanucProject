@{
    Layout = "_Layout";
    ViewData["Title"] = "Program Detay";
}

@section Head {
    <style>
        :root {
            --gold-start: #f09701;
            --gold-end: #face00;
            --gold-grad: linear-gradient(90deg, var(--gold-start), var(--gold-end));
            --gradient-primary: var(--gold-grad);
        }

        body {
            background:
                radial-gradient(circle at 35% 50%, #b87900 0%, #704800 30%, #2f1f00 55%, #0f0f0f 100%);
            background-attachment: fixed;
            background-size: cover;
        }

        .content-area {
            background: transparent !important;
        }

        .empty-program-wrap {
            min-height: calc(100vh - 140px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .empty-program-card {
            width: 100%;
            max-width: 760px;
            background: rgba(255, 255, 255, 0.92);
            border-radius: 28px;
            padding: 3rem 2.5rem;
            text-align: center;
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.18);
            border: 1px solid rgba(255, 255, 255, 0.30);
        }

        .empty-program-icon {
            width: 96px;
            height: 96px;
            margin: 0 auto 1.5rem auto;
            border-radius: 24px;
            background: linear-gradient(90deg, #c77700, #d4a800);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            box-shadow: 0 12px 24px rgba(199, 119, 0, 0.25);
        }

        .empty-program-title {
            font-size: 2.1rem;
            font-weight: 700;
            color: #222222;
            margin-bottom: .75rem;
        }

        .empty-program-subtitle {
            font-size: 1.05rem;
            font-weight: 500;
            color: #7a5a00;
            margin-bottom: 1rem;
        }

        .empty-program-text {
            max-width: 560px;
            margin: 0 auto 2rem auto;
            color: #667085;
            font-size: 1rem;
            line-height: 1.8;
        }

        .empty-program-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .empty-program-actions .btn {
            min-width: 190px;
            border-radius: 14px;
            padding: .85rem 1.2rem;
            font-weight: 600;
        }

        .btn-gold {
            background: linear-gradient(90deg, #c77700, #d4a800);
            color: white;
            border: none;
        }

        .btn-gold:hover {
            color: white;
            opacity: .95;
        }

        .btn-dark-soft {
            background: #222222;
            color: white;
            border: none;
        }

        .btn-dark-soft:hover {
            color: white;
            background: #111111;
        }

        @@media (max-width: 768px) {
            .empty-program-card {
                padding: 2rem 1.25rem;
                border-radius: 22px;
            }

            .empty-program-title {
                font-size: 1.7rem;
            }

            .empty-program-text {
                font-size: .95rem;
            }

            .empty-program-actions .btn {
                width: 100%;
            }
        }
    </style>
}

<div class="empty-program-wrap">
    <div class="empty-program-card">
        <div class="empty-program-icon">
            <i class="fas fa-folder-open"></i>
        </div>

        <h1 class="empty-program-title">Gösterilecek program bulunamadı</h1>

        <p class="empty-program-subtitle">
            Program detay ekranında gösterilecek aktif bir kayıt yok.
        </p>

        <p class="empty-program-text">
            Henüz kayıtlı bir program verisi bulunmuyor olabilir ya da seçtiğiniz program kaldırılmış olabilir.
            Yeni veriler geldiğinde bu alanda detayları görüntüleyebilirsiniz.
        </p>

        <div class="empty-program-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-gold">
                <i class="fas fa-home me-2"></i>Ana Sayfaya Dön
            </a>

            <a asp-controller="ProgramDetay" asp-action="Index" class="btn btn-dark-soft">
                <i class="fas fa-rotate-right me-2"></i>Tekrar Dene
            </a>
        </div>
    </div>
</div>