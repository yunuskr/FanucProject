@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    bool IsActive(string ctrl, string? act = null) =>
        string.Equals(currentController, ctrl, StringComparison.OrdinalIgnoreCase) &&
        (act == null || string.Equals(currentAction, act, StringComparison.OrdinalIgnoreCase));

    string pageTitle = ViewData["Title"]?.ToString() ?? "Admin Panel";

    bool userMenuOpen = currentController == "OperatorTable" || currentController == "AdminTable";
}
<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <title>@pageTitle - RoboEye Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="RoboEye Admin Yönetim Paneli" name="description" />
    <meta content="Robentex End. Ver. A.Ş." name="author" />

    <link rel="shortcut icon" href="~/favicon.ico" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">
    <link href="~/lib/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" asp-append-version="true">
        <link href="~/lib/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet" />
        <link href="~/css/site.css" rel="stylesheet" />

        <style>
                :root {
                    --brand-gradient: linear-gradient(90deg, #c77700, #d4a800);
                    --sidebar-width: 280px;
                    --topbar-height: 70px;
                    --glass-bg: rgba(255, 255, 255, 0.95);
                    --glass-border: rgba(255, 255, 255, 0.3);
                    --shadow-glass: 0 8px 32px rgba(31, 38, 135, 0.2);
                    --border-radius: 15px;
                    --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
                }

                * {
                    box-sizing: border-box;
                }

                body {
                    font-family: 'Poppins', sans-serif;
                    background: linear-gradient(135deg, #f09701 0%, #face00 50%, #f09701 100%);
                    background-attachment: fixed;
                    min-height: 100vh;
                    color: #2c3e50;
                    overflow-x: hidden;
                    margin: 0;
                }

                .layout-wrapper {
                    display: flex;
                    min-height: 100vh;
                    width: 100%;
                }

                .sidebar {
                    width: var(--sidebar-width);
                    background: #222222;
                    backdrop-filter: blur(20px);
                    border-right: 1px solid var(--glass-border);
                    box-shadow: var(--shadow-glass);
                    position: fixed;
                    height: 100vh;
                    left: 0;
                    top: 0;
                    z-index: 1000;
                    overflow-y: auto;
                    transition: var(--transition);
                }

                .sidebar-header {
                    padding: 1.5rem;
                    text-align: center;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                    margin-bottom: 1rem;
                }

                .sidebar-logo {
                    font-size: 1.8rem;
                    font-weight: 700;
                    background: var(--brand-gradient);
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                    margin-bottom: 0.5rem;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: .5rem;
                }

                .sidebar-tagline {
                    color: #ffffff;
                    font-size: 0.85rem;
                    font-weight: 400;
                }

                .sidebar-nav {
                    padding: 0 1rem;
                }

                .nav-section {
                    margin-bottom: 2rem;
                }

                .nav-section-title {
                    font-size: 0.75rem;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    color: #ffffff;
                    margin-bottom: 1rem;
                    padding: 0 1rem;
                }

                .nav-item {
                    margin-bottom: .5rem;
                }

                .nav-link {
                    display: flex;
                    align-items: center;
                    padding: 1rem;
                    border-radius: var(--border-radius);
                    text-decoration: none;
                    color: #ffffff;
                    transition: var(--transition);
                    font-weight: 500;
                }

                .nav-link:hover,
                .nav-link.active {
                    background: var(--brand-gradient);
                    color: white;
                    transform: translateX(5px);
                    text-decoration: none;
                    box-shadow: var(--shadow-glass);
                }

                .nav-link i {
                    width: 20px;
                    margin-right: 1rem;
                    font-size: 1.05rem;
                    text-align: center;
                }

                .has-submenu {
                    position: relative;
                }

                .submenu-toggle {
                    justify-content: flex-start;
                    position: relative;
                }

                .submenu-arrow {
                    margin-left: auto !important;
                    margin-right: 0 !important;
                    width: auto !important;
                    font-size: .85rem !important;
                    transition: transform 0.3s ease;
                }

                .sub-links {
                    margin-top: .35rem;
                    margin-left: .75rem;
                    display: flex;
                    flex-direction: column;
                    gap: .35rem;
                    max-height: 0;
                    overflow: hidden;
                    opacity: 0;
                    pointer-events: none;
                    transition: max-height 0.35s ease, opacity 0.25s ease;
                }

                .has-submenu:hover .sub-links,
                .has-submenu.submenu-open .sub-links {
                    max-height: 200px;
                    opacity: 1;
                    pointer-events: auto;
                }

                .has-submenu:hover .submenu-arrow,
                .has-submenu.submenu-open .submenu-arrow {
                    transform: rotate(180deg);
                }

                .sub-link {
                    display: flex;
                    align-items: center;
                    padding: .8rem 1rem;
                    border-radius: 12px;
                    text-decoration: none;
                    color: rgba(255, 255, 255, .85);
                    transition: var(--transition);
                    font-size: .95rem;
                }

                .sub-link:hover,
                .sub-link.active {
                    background: rgba(255, 255, 255, .10);
                    color: #fff;
                    text-decoration: none;
                }

                .main-content {
                    margin-left: var(--sidebar-width) !important;
                    width: calc(100% - var(--sidebar-width));
                    display: flex;
                    flex-direction: column;
                    min-height: 100vh;
                    background: none !important;
                    padding: 0 !important;
                }

                .topbar {
                    height: var(--topbar-height);
                    background: #222222;
                    backdrop-filter: blur(20px);
                    border-bottom: 1px solid var(--glass-border);
                    box-shadow: var(--shadow-glass);
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    padding: 0 2rem;
                    position: sticky;
                    top: 0;
                    z-index: 999;
                }

                .topbar-title {
                    font-size: 1.35rem;
                    font-weight: 600;
                    color: #ffffff;
                }

                .topbar-actions {
                    display: flex;
                    align-items: center;
                    gap: 1rem;
                }

                .topbar-user {
                    display: flex;
                    align-items: center;
                    gap: 0.75rem;
                    padding: 0.55rem 1rem;
                    background: rgba(255, 255, 255, 1);
                    border-radius: var(--border-radius);
                    cursor: pointer;
                    transition: var(--transition);
                }

                .topbar-user:hover {
                    background: var(--brand-gradient);
                    color: white;
                }

                .topbar-avatar {
                    width: 35px;
                    height: 35px;
                    background: var(--brand-gradient);
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: white;
                    font-weight: 600;
                    flex-shrink: 0;
                }

                .content-area {
                    flex: 1;
                    padding: 2rem;
                    background: radial-gradient(circle at 35% 50%, #b87900 0%, #704800 30%, #2f1f00 55%, #0f0f0f 100%);
                }

                .page-shell {
                    background: transparent;
                    border: none;
                    border-radius: 22px;
                    padding: 0;
                    box-shadow: none;
                }

                .dropdown-menu {
                    background: var(--glass-bg);
                    backdrop-filter: blur(20px);
                    border: 1px solid var(--glass-border);
                    box-shadow: var(--shadow-glass);
                    border-radius: var(--border-radius);
                    overflow: hidden;
                }

                .dropdown-item {
                    color: #2c3e50;
                    padding: 0.75rem 1rem;
                    transition: var(--transition);
                }

                .dropdown-item:hover {
                    background: var(--brand-gradient);
                    color: white;
                }

                @@media (max-width: 768px) {
                    .sidebar {
                        transform: translateX(-100%);
                        transition: transform 0.3s ease;
                    }

                    .sidebar.show {
                        transform: translateX(0);
                    }

                    .main-content {
                        margin-left: 0 !important;
                        width: 100% !important;
                    }

                    .mobile-toggle {
                        display: block !important;
                    }

                    .has-submenu:hover .sub-links {
                        max-height: 0;
                        opacity: 0;
                        pointer-events: none;
                    }

                    .has-submenu.submenu-open .sub-links {
                        max-height: 200px;
                        opacity: 1;
                        pointer-events: auto;
                    }
                }

                @@media (min-width: 769px) {
                    .mobile-toggle {
                        display: none !important;
                    }
                }

                .mobile-toggle {
                    background: none;
                    border: none;
                    font-size: 1.2rem;
                    color: #fff;
                    cursor: pointer;
                    padding: 0.5rem;
                    border-radius: var(--border-radius);
                }
        </style>

        @RenderSection("Styles", required: false)
    </head>

    <body>
        <div class="layout-wrapper">
            <nav class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <div class="sidebar-logo">
                        <img src="/images/favicon-ArcTab.png" alt="Robot"
                             style="width:34px; height:34px; object-fit:contain; filter: drop-shadow(0 1px 1px rgba(0,0,0,.2));" />
                        ArcTab
                    </div>
                    <div class="sidebar-tagline">Admin Yönetim Paneli</div>
                </div>

                <div class="sidebar-nav">
                    <div class="nav-section">
                        <div class="nav-section-title">Admin Menü</div>

                        <div class="nav-item">
                            <a class="nav-link @(IsActive("AdminHome") ? "active" : "")" asp-area="Admin"
                                   asp-controller="AdminHome" asp-action="Index">
                                <i class="fas fa-house"></i>
                                <span>Admin Anasayfa</span>
                            </a>
                        </div>

                        <div class="nav-item has-submenu @(userMenuOpen ? "submenu-open" : "")">
                            <a class="nav-link submenu-toggle @((userMenuOpen) ? "active" : "")" href="javascript:void(0);">
                                <i class="fas fa-users"></i>
                                <span>Kullanıcı Yönetimi</span>
                                <i class="fas fa-chevron-down submenu-arrow"></i>
                            </a>

                            <div class="sub-links">
                                <a class="sub-link @(IsActive("OperatorTable") ? "active" : "")" asp-area="Admin"
                                       asp-controller="OperatorTable" asp-action="Index">
                                    Operatörler
                                </a>

                                <a class="sub-link @(IsActive("AdminTable") ? "active" : "")" asp-area="Admin"
                                       asp-controller="AdminTable" asp-action="Index">
                                    Adminler
                                </a>
                            </div>
                        </div>

                        <div class="nav-item">
                            <a class="nav-link @(IsActive("ProgramVerileri") ? "active" : "")" asp-area="Admin"
                                   asp-controller="ProgramVerileri" asp-action="Index">
                                <i class="fas fa-database"></i>
                                <span>Program Verileri</span>
                            </a>
                        </div>

                        <div class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-arrow-left"></i>
                                <span>Ana Panele Dön</span>
                            </a>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="main-content">
                <header class="topbar">
                    <div class="d-flex align-items-center">
                        <button class="mobile-toggle me-3" id="mobileToggle">
                            <i class="fas fa-bars"></i>
                        </button>
                        <div class="topbar-title">@pageTitle</div>
                    </div>

                    <div class="topbar-actions">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <div class="topbar-user" data-bs-toggle="dropdown" role="button">
                                    <div class="topbar-avatar">
                                        @User.Identity!.Name?.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="d-none d-md-block">
                                        <div style="font-size: 0.9rem; font-weight: 500;">@User.Identity!.Name</div>
                                        <div style="font-size: 0.75rem; color: #6c757d;">Admin</div>
                                    </div>
                                    <i class="fas fa-chevron-down ms-1"></i>
                                </div>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index">
                                            <i class="fas fa-home me-2"></i>Kullanıcı Paneline Dön
                                        </a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <form method="post" asp-area="" asp-controller="Login" asp-action="Logout">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-light" asp-controller="Login" asp-action="Index">
                                <i class="fas fa-sign-in-alt me-1"></i>Giriş Yap
                            </a>
                        }
                    </div>
                </header>

                <main class="content-area">
                    <div class="page-shell">
                        @RenderBody()
                    </div>
                </main>
            </div>
        </div>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js"></script>

        <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const sidebar = document.getElementById('sidebar');
                    const mobileToggle = document.getElementById('mobileToggle');
                    const submenuItems = document.querySelectorAll('.has-submenu');

                    if (mobileToggle) {
                        mobileToggle.addEventListener('click', function () {
                            sidebar.classList.toggle('show');
                        });
                    }

                    document.addEventListener('click', function (e) {
                        if (window.innerWidth <= 768 &&
                            !sidebar.contains(e.target) &&
                            !mobileToggle?.contains(e.target) &&
                            sidebar.classList.contains('show')) {
                            sidebar.classList.remove('show');
                        }
                    });

                    submenuItems.forEach(function (item) {
                        const toggle = item.querySelector('.submenu-toggle');

                        if (toggle) {
                            toggle.addEventListener('click', function (e) {
                                if (window.innerWidth <= 768) {
                                    e.preventDefault();
                                    item.classList.toggle('submenu-open');
                                }
                            });
                        }
                    });
                });
        </script>

        @RenderSection("Scripts", required: false)
    </body>

</html>