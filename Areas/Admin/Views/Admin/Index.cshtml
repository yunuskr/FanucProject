@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Anasayfa";
}

<div class="admin-welcome-page">
    <div class="welcome-card">
        <div class="welcome-icon">
            <img src="~/images/favicon-ArcTab.png" alt="Robot" style="width:56px; height:56px; object-fit:contain;" />
        </div>

        <h1 class="welcome-title">Merhaba, hoş geldiniz</h1>
        <p class="welcome-subtitle">
            ArcTab admin yönetim paneline hoş geldiniz.
        </p>

        <p class="welcome-text">
            Bu alandan kullanıcı yönetimi, program verileri ve diğer yönetim işlemlerini
            güvenli şekilde gerçekleştirebilirsiniz.
        </p>

        <div class="welcome-date-box">
            <div class="date-item">
                <span class="date-label">Tarih</span>
                <strong id="nowDateText">--</strong>
            </div>
            <div class="date-item">
                <span class="date-label">Saat</span>
                <strong id="nowTimeText">--</strong>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .admin-welcome-page {
            min-height: calc(100vh - 170px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .welcome-card {
            width: 100%;
            max-width: 760px;
            text-align: center;
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(255, 255, 255, 0.35);
            border-radius: 24px;
            padding: 3rem 2rem;
            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.10);
            backdrop-filter: blur(12px);
        }

        .welcome-icon {
            width: 96px;
            height: 96px;
            margin: 0 auto 1.5rem auto;
            border-radius: 24px;
            background: linear-gradient(90deg, #c77700, #d4a800);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 24px rgba(199, 119, 0, 0.25);
        }

        .welcome-title {
            font-size: 2rem;
            font-weight: 700;
            color: #222222;
            margin-bottom: .75rem;
        }

        .welcome-subtitle {
            font-size: 1.05rem;
            font-weight: 500;
            color: #6b4a00;
            margin-bottom: 1rem;
        }

        .welcome-text {
            max-width: 560px;
            margin: 0 auto 2rem auto;
            color: #5f6b7a;
            font-size: 1rem;
            line-height: 1.8;
        }

        .welcome-date-box {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 1rem;
        }

        .date-item {
            min-width: 180px;
            background: rgba(199, 119, 0, 0.10);
            border: 1px solid rgba(199, 119, 0, 0.12);
            border-radius: 16px;
            padding: 1rem 1.25rem;
        }

        .date-label {
            display: block;
            font-size: .82rem;
            color: #7a7a7a;
            margin-bottom: .35rem;
        }

        .date-item strong {
            font-size: 1rem;
            color: #222222;
        }

        @@media (max-width: 768px) {
            .welcome-card {
                padding: 2rem 1.25rem;
            }

            .welcome-title {
                font-size: 1.6rem;
            }

            .welcome-text {
                font-size: .95rem;
            }

            .date-item {
                width: 100%;
            }
        }
    </style>
}

@section Scripts {
    <script>
        function renderNow() {
            const now = new Date();

            const dateFmt = new Intl.DateTimeFormat('tr-TR', {
                weekday: 'long',
                day: '2-digit',
                month: 'long',
                year: 'numeric'
            });

            const timeFmt = new Intl.DateTimeFormat('tr-TR', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });

            document.getElementById('nowDateText').textContent = dateFmt.format(now);
            document.getElementById('nowTimeText').textContent = timeFmt.format(now);
        }

        renderNow();
        setInterval(renderNow, 1000);
    </script>
}